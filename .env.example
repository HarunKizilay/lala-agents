# LALA Ajan Sistemi — API Anahtarları
# Bu dosyayı .env olarak kopyalayın: copy .env.example .env

# ── 1. NVIDIA NIM (ÖNCELİKLİ — ücretsiz, 1M token context) ──────────────────
# API key: https://build.nvidia.com → "API Keys"
NVIDIA_API_KEY=your_nvidia_api_key_here
# Ücretsiz modeller (Free Endpoint):
#   deepseek-ai/deepseek-v4-flash    → 284B, hızlı, ajan işleri
#   deepseek-ai/deepseek-v4-pro      → 1M context, derin analiz
#   nvidia/nemotron-3-super-120b-a12b → NVIDIA native, tool calling
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash

# ── 2. LM Studio (yerel — okul PC, Tailscale üzerinden) ──────────────────────
LM_STUDIO_BASE_URL=http://100.109.228.17:1234/v1
LM_STUDIO_MODEL=google/gemma-4-e4b

# ── 3. OpenRouter ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_DEFAULT_MODEL=google/gemma-4-31b-it:free

# ── 4. GitHub Models ──────────────────────────────────────────────────────────
GITHUB_MODELS_TOKEN=your_github_pat_here
GITHUB_DEFAULT_MODEL=gpt-4o-mini

# ── 5. Gemini ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_FLASH=gemini-2.0-flash

# ── 6. Anthropic (son yedek — Claude Code için sakla) ────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=1447186368

# ── LALA Proje Yolları ────────────────────────────────────────────────────────
LALA_PROJECT_PATH=C:/LALA/ZEKY
