# LALA Ajan Sistemi — API Anahtarları
# Bu dosyayı .env olarak kopyalayın: copy .env.example .env

# 1. LM Studio (yerel — ücretsiz, öncelikli)
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model

# 2. OpenRouter (ücretsiz modeller: mistralai/mistral-7b-instruct:free)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# 3. GitHub Models (GitHub Personal Access Token)
GITHUB_TOKEN=your_github_pat_here
GITHUB_MODELS_MODEL=gpt-4o-mini

# 4. Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_PRO=gemini-2.0-flash

# 5. Anthropic (son yedek)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
